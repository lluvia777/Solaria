<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_main.xml
    Root layout for the Solaria UV Index Home Screen.
    Uses a ScrollView body + fixed bottom navigation bar.
-->
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_cream"
    tools:context=".MainActivity">

    <!-- ══════════════════════════════════════
         SCROLLABLE CONTENT AREA
    ══════════════════════════════════════ -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/bottomNavBar"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="16dp">

            <!-- ══════════════════════════════
                 HEADER ROW
            ══════════════════════════════ -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp">

                <!-- Hamburger Menu -->
                <LinearLayout
                    android:id="@+id/btnMenu"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_alignParentStart="true"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="8dp"
                    android:clickable="true"
                    android:focusable="true">

                    <View
                        android:layout_width="22dp"
                        android:layout_height="2.5dp"
                        android:layout_marginBottom="4dp"
                        android:background="@color/text_medium" />
                    <View
                        android:layout_width="22dp"
                        android:layout_height="2.5dp"
                        android:layout_marginBottom="4dp"
                        android:background="@color/text_medium" />
                    <View
                        android:layout_width="22dp"
                        android:layout_height="2.5dp"
                        android:background="@color/text_medium" />
                </LinearLayout>

                <!-- Center Title Block -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:orientation="vertical"
                    android:gravity="center">

                    <!-- "Hello User!" row with sun emoji -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="☀️"
                            android:textSize="22sp"
                            android:layout_marginEnd="4dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="SOLARIA"
                            android:fontFamily="@font/silkscreen_regular"
                            android:textSize="22sp"
                            android:textStyle="normal"
                            android:textColor="@color/warm_pink"
                             />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="✦"
                            android:textSize="10sp"
                            android:textColor="@color/sun_yellow"
                            android:layout_marginStart="4dp" />
                    </LinearLayout>

                    <!-- "♥ SOLARIA ♥" row -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="4dp"
                            android:text="🐾"
                            android:textColor="@color/warm_pink"
                            android:textSize="10sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"

                            android:letterSpacing="0.2"
                            android:text="HELLO"
                            android:fontFamily="@font/silkscreen_regular"
                            android:textColor="@color/primary_orange"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:layout_marginStart="4dp"
                            android:text="🐾"
                            android:textColor="@color/warm_pink"
                            android:textSize="10sp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Help "?" Button -->
                <TextView
                    android:id="@+id/btnHelp"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_centerVertical="true"
                    android:layout_alignParentEnd="true"
                    android:text="@string/help_question"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_medium"
                    android:gravity="center"
                    android:background="@drawable/bg_card_rounded"
                    android:clickable="true"
                    android:focusable="true" />

            </RelativeLayout>

            <!-- ══════════════════════════════
                 UV GAUGE CARD
            ══════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_uv_card"
                android:elevation="4dp"
                android:orientation="horizontal"
                android:padding="14dp">

                <!-- Left side: gauge + value + risk badge -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center_horizontal">

                    <!-- Title -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CURRENT UV INDEX"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_medium"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="8dp" />

                    <!-- UV Gauge Image Placeholder -->
                    <!--
                         Replace this ImageView src with:
                         android:src="@drawable/uv_widget"
                         once you add uv_widget.png to res/drawable/
                    -->
                    <ImageView
                        android:id="@+id/uvGaugeImage"
                        android:layout_width="150dp"
                        android:layout_height="90dp"
                        android:src="@android:drawable/ic_menu_compass"
                        android:scaleType="fitCenter"
                        android:contentDescription="UV Gauge"
                        android:layout_marginBottom="4dp" />

                    <!-- UV Index Value -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="UV "
                            android:textSize="26sp"
                            android:textStyle="bold"
                            android:textColor="@color/lilac_blue" />

                        <TextView
                            android:id="@+id/tvUVValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="7.5"
                            android:textSize="36sp"
                            android:textStyle="bold"
                            android:textColor="@color/primary_orange" />
                    </LinearLayout>

                    <!-- Risk Level Badge -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_risk_badge"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:paddingLeft="10dp"
                        android:paddingRight="10dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp">

                        <!-- Replace with: android:src="@drawable/warning_icon" -->
                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@android:drawable/ic_dialog_alert"
                            android:contentDescription="Warning"
                            android:layout_marginEnd="6dp" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="RISK LEVEL:"
                                android:textSize="9sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_light"
                                android:letterSpacing="0.05" />

                            <TextView
                                android:id="@+id/tvRiskLevel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="APPLY SUNSCREEN"
                                android:textColor="@color/warm_pink"
                                android:textSize="16sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>

                <!-- Right side: Cat beach illustration -->
                <!--
                     Replace android:src with:
                     android:src="@drawable/cat_sunsafe"
                     once you add cat_sunsafe.png to res/drawable/
                -->
                <ImageView
                    android:id="@+id/catIllustration"
                    android:layout_width="0dp"
                    android:layout_height="200dp"
                    android:layout_marginStart="4dp"
                    android:layout_weight="0.9"
                    android:contentDescription="Cute cat beach illustration"
                    android:scaleType="fitCenter"
                    android:src="@android:drawable/ic_menu_gallery" />

            </LinearLayout>

            <!-- ══════════════════════════════
                 INFO CARD (4 columns)
            ══════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_card_rounded"
                android:elevation="2dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="14dp"
                android:paddingBottom="14dp">

                <!-- 1. Best Time Outdoors -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:paddingLeft="4dp"
                    android:paddingRight="4dp">

                    <!-- Replace with: android:src="@drawable/clock_icon" -->
                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:src="@android:drawable/ic_menu_recent_history"
                        android:contentDescription="Best time"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="BEST TIME\nOUTDOORS"
                        android:textSize="8sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_light"
                        android:gravity="center"
                        android:letterSpacing="0.05"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="7AM – 10AM\n5PM – 7PM"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="@color/warm_pink"
                        android:gravity="center"
                        android:lineSpacingExtra="2dp" />
                </LinearLayout>

                <!-- Divider 1 -->
                <View
                    android:layout_width="1dp"
                    android:layout_height="60dp"
                    android:background="@drawable/bg_divider_vertical" />

                <!-- 2. UV Peaks At -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:paddingLeft="4dp"
                    android:paddingRight="4dp">

                    <!-- Replace with: android:src="@drawable/sun_icon" -->
                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:src="@android:drawable/ic_menu_day"
                        android:contentDescription="UV peaks"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="UV PEAKS AT"
                        android:textSize="8sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_light"
                        android:gravity="center"
                        android:letterSpacing="0.05"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="12PM – 2PM"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary_orange"
                        android:gravity="center" />
                </LinearLayout>

                <!-- Divider 2 -->
                <View
                    android:layout_width="1dp"
                    android:layout_height="60dp"
                    android:background="@drawable/bg_divider_vertical" />

                <!-- 3. Shade Recommended -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:paddingLeft="4dp"
                    android:paddingRight="4dp">

                    <!-- Replace with: android:src="@drawable/umbrella_icon" -->
                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:src="@android:drawable/ic_menu_share"
                        android:contentDescription="Shade"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SHADE\nRECOMMENDED"
                        android:textSize="8sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_light"
                        android:gravity="center"
                        android:letterSpacing="0.05"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:id="@+id/tvShade"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Yes"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/warm_pink"
                        android:gravity="center" />
                </LinearLayout>

                <!-- Divider 3 -->
                <View
                    android:layout_width="1dp"
                    android:layout_height="60dp"
                    android:background="@drawable/bg_divider_vertical" />

                <!-- 4. Today's Weather -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:paddingLeft="4dp"
                    android:paddingRight="4dp">

                    <!-- Replace with: android:src="@drawable/cloud_icon" -->
                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:src="@android:drawable/ic_menu_upload_you_tube"
                        android:contentDescription="Weather"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TODAY'S\nWEATHER"
                        android:textSize="8sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_light"
                        android:gravity="center"
                        android:letterSpacing="0.05"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Partly Cloudy\n28°C"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="@color/lilac_blue"
                        android:gravity="center"
                        android:lineSpacingExtra="2dp" />
                </LinearLayout>

            </LinearLayout>

            <!-- ══════════════════════════════
                 REFRESH BUTTON


            <!- ══════════════════════════════
                 SETTINGS CARD (Reminder + Offline)
            ══════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="156dp"
                android:background="@drawable/bg_card_rounded"
                android:elevation="2dp"
                android:orientation="vertical"
                android:paddingLeft="16dp"
                android:paddingTop="8dp"
                android:paddingRight="16dp"
                android:paddingBottom="8dp">

                <!-- Reminder Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp">

                    <!-- Bell Icon Box -->
                    <FrameLayout
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_marginEnd="12dp"
                        android:background="@drawable/bg_icon_bell">

                        <!-- Replace with: android:src="@drawable/bell_icon" -->
                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_gravity="center"
                            android:contentDescription="Reminder bell"
                            android:src="@android:drawable/ic_dialog_info"
                            app:tint="@color/white" />
                    </FrameLayout>

                    <!-- Reminder Text -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Reminder On"
                            android:textColor="@color/text_dark"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Get notified when UV is high"
                            android:textColor="@color/text_light"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <!-- Reminder Toggle -->
                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switchReminder"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        android:thumb="@null" />
                    <!--
                        To style the switch with pastel colors, use a ThumbDrawable
                        and TrackDrawable in your theme, or use a custom SwitchMaterial.
                        The simplest option is to set app:thumbTint and app:trackTint
                        programmatically in MainActivity.java (see comments there).
                    -->
                </LinearLayout>

                <!-- Horizontal Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.8dp"
                    android:layout_marginTop="2dp"
                    android:layout_marginBottom="2dp"
                    android:background="@color/divider_color" />

                <!-- Offline Mode Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp">

                    <!-- Offline Icon Box -->
                    <FrameLayout
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_marginEnd="12dp"
                        android:background="@drawable/bg_icon_offline">

                        <!-- Replace with: android:src="@drawable/offline_icon" -->
                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_gravity="center"
                            android:contentDescription="Offline mode"
                            android:src="@android:drawable/ic_lock_silent_mode_off"
                            app:tint="@color/white" />
                    </FrameLayout>

                    <!-- Offline Text -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Offline Mode: Not active"
                            android:textColor="@color/text_dark"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Enable to use cached data only"
                            android:textColor="@color/text_light"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <!-- Offline Toggle -->

                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- ══════════════════════════════════════
         BOTTOM NAVIGATION BAR (fixed)
    ══════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/bottomNavBar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_alignParentBottom="true"
        android:background="@drawable/bg_bottom_nav"
        android:elevation="8dp"
        android:orientation="horizontal">

        <!-- Tab 1: UV Today (selected by default) -->
        <LinearLayout
            android:id="@+id/tabUvToday"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_nav_selected"
            android:paddingLeft="12dp"
            android:paddingRight="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:clickable="true"
            android:focusable="true">

            <!-- Replace with: android:src="@drawable/sun_icon" -->
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@android:drawable/ic_menu_day"
                android:contentDescription="UV Today"
                android:layout_marginBottom="2dp" />

            <TextView
                android:id="@+id/tvNavUvToday"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="UV Today"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@color/nav_selected_text" />
        </LinearLayout>


        <LinearLayout
            android:id="@+id/btnSettings"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingLeft="12dp"
            android:paddingRight="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:clickable="true"
            android:focusable="true">


            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@android:drawable/ic_menu_myplaces"
                android:contentDescription="Settings" />

            <TextView
                android:id="@+id/tvNavProfile"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Settings"
                android:textSize="10sp"
                android:textColor="@color/nav_unselected_text" />
        </LinearLayout>

    </LinearLayout>

</RelativeLayout>
