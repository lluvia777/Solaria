<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_cream"
    tools:context=".MainActivity">

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/bottomNavBar"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="16dp">

            <!-- HEADER -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp">

                <LinearLayout
                    android:id="@+id/btnMenu"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_centerVertical="true"
                    android:layout_alignParentStart="true"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_card_rounded"
                    android:clickable="true"
                    android:focusable="true"
                    android:elevation="2dp">
                    <View android:layout_width="20dp" android:layout_height="2dp" android:layout_marginBottom="4dp" android:background="@color/text_medium" />
                    <View android:layout_width="20dp" android:layout_height="2dp" android:layout_marginBottom="4dp" android:background="@color/text_medium" />
                    <View android:layout_width="20dp" android:layout_height="2dp" android:background="@color/text_medium" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:orientation="vertical"
                    android:gravity="center">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="∿∿" android:textSize="12sp" android:textColor="@color/text_light" android:layout_marginEnd="4dp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="☀️" android:textSize="24sp" android:layout_marginEnd="2dp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="SOLARIA" android:fontFamily="@font/silkscreen_regular" android:textSize="24sp" android:textColor="@color/warm_pink" android:letterSpacing="0.05" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="∿∿" android:textSize="12sp" android:textColor="@color/text_light" android:layout_marginStart="4dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/bg_hello_badge"
                        android:paddingLeft="10dp"
                        android:paddingRight="10dp"
                        android:paddingTop="3dp"
                        android:paddingBottom="3dp"
                        android:layout_marginTop="2dp">

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="HELLO" android:fontFamily="@font/silkscreen_regular" android:textColor="@color/primary_orange" android:textSize="13sp" android:letterSpacing="0.15" />
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:id="@+id/btnHelp"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_centerVertical="true"
                    android:layout_alignParentEnd="true"
                    android:text="?"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_medium"
                    android:gravity="center"
                    android:background="@drawable/bg_card_rounded"
                    android:clickable="true"
                    android:focusable="true"
                    android:elevation="2dp" />
            </RelativeLayout>

            <!-- MAIN UV CARD -->

            <!-- 4 INFO BOXES -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="353dp"
                android:layout_marginBottom="14dp"
                android:background="@drawable/bg_uv_card"
                android:elevation="4dp"
                android:orientation="horizontal"
                android:padding="14dp">

                <!-- LEFT COLUMN -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center_horizontal"
                    android:orientation="vertical">

                    <!-- CURRENT UV INDEX label -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="✦ "
                            android:textColor="@color/sun_yellow"
                            android:textSize="9sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/silkscreen_regular"
                            android:letterSpacing="0.08"
                            android:text="CURRENT UV INDEX"
                            android:textColor="@color/text_medium"
                            android:textSize="9sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=" ✦"
                            android:textColor="@color/sun_yellow"
                            android:textSize="9sp" />
                    </LinearLayout>

                    <!-- UV number box -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:background="@drawable/bg_uv_number_box"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="4dp"
                            android:fontFamily="@font/silkscreen_regular"
                            android:text="UV"
                            android:textColor="@color/lilac_blue"
                            android:textSize="28sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvUVValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/silkscreen_regular"
                            android:text="7.5"
                            android:textColor="@color/primary_orange"
                            android:textSize="44sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- RISK LEVEL label -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="✦ "
                            android:textColor="@color/warm_pink"
                            android:textSize="10sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/silkscreen_regular"
                            android:letterSpacing="0.05"
                            android:text="RISK LEVEL:"
                            android:textColor="@color/text_medium"
                            android:textSize="10sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=" ✦"
                            android:textColor="@color/warm_pink"
                            android:textSize="10sp" />
                    </LinearLayout>

                    <!-- Risk badge -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:layout_marginBottom="10dp"
                        android:background="@drawable/bg_risk_badge_pink"
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:paddingLeft="10dp"
                        android:paddingTop="10dp"
                        android:paddingRight="10dp"
                        android:paddingBottom="10dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="☀️ "
                            android:textSize="20sp" />

                        <TextView
                            android:id="@+id/tvRiskLevel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/silkscreen_regular"
                            android:text="High risk
                            Apply SUNSCREEN"
                            android:textColor="@android:color/white"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Guidance box -->
                    <LinearLayout
                        android:layout_width="169dp"
                        android:layout_height="101dp"
                        android:background="@drawable/bg_guidance_box"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingLeft="10dp"
                        android:paddingTop="8dp"
                        android:paddingRight="10dp"
                        android:paddingBottom="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp"
                            android:text="🧴"
                            android:textSize="22sp" />

                        <TextView
                            android:id="@+id/tvGuidance"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:lineSpacingExtra="2dp"
                            android:text="Reapply every\n2 hours while outdoors."
                            android:textColor="@color/text_medium"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                </LinearLayout>

                <!-- RIGHT: Cat illustration -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_weight="0.9"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:id="@+id/catIllustration"
                        android:layout_width="match_parent"
                        android:layout_height="339dp"
                        android:background="@drawable/bg_cat_frame"
                        android:contentDescription="UV-based Solaria cat visual"
                        android:scaleType="fitCenter"
                        android:src="@drawable/cat_high" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:orientation="horizontal"
                android:weightSum="4">

                <!-- 1. REAPPLY RULE -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="5dp"
                    android:background="@drawable/bg_info_card"
                    android:elevation="2dp"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"
                    android:paddingLeft="6dp"
                    android:paddingRight="6dp">
                    <FrameLayout android:layout_width="44dp" android:layout_height="44dp" android:layout_marginBottom="6dp">
                        <View android:layout_width="44dp" android:layout_height="44dp" android:background="@drawable/bg_icon_circle_pink" />
                        <ImageView android:layout_width="26dp" android:layout_height="26dp" android:layout_gravity="center" android:src="@drawable/ic_reapply" android:contentDescription="Reapply icon" />
                    </FrameLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="REAPPLY\nRULE" android:textSize="8sp" android:textStyle="bold" android:textColor="@color/text_light" android:gravity="center" android:letterSpacing="0.05" android:fontFamily="@font/silkscreen_regular" android:layout_marginBottom="6dp" />
                    <TextView android:id="@+id/tvReapplyRule" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Every 2h" android:textSize="12sp" android:textStyle="bold" android:textColor="@color/warm_pink" android:gravity="center" android:background="@drawable/bg_value_badge_pink" android:paddingTop="5dp" android:paddingBottom="5dp" />
                </LinearLayout>

                <!-- 2. TODAY'S WEATHER -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="5dp"
                    android:background="@drawable/bg_info_card_selected"
                    android:elevation="2dp"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"
                    android:paddingLeft="6dp"
                    android:paddingRight="6dp">
                    <FrameLayout android:layout_width="44dp" android:layout_height="44dp" android:layout_marginBottom="6dp">
                        <View android:layout_width="44dp" android:layout_height="44dp" android:background="@drawable/bg_icon_circle_blue" />
                        <ImageView android:id="@+id/imgWeatherIcon" android:layout_width="28dp" android:layout_height="28dp" android:layout_gravity="center" android:src="@drawable/ic_weather_partly_cloudy" android:contentDescription="Weather icon" />
                    </FrameLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="TODAY'S\nWEATHER" android:textSize="8sp" android:textStyle="bold" android:textColor="@color/text_light" android:gravity="center" android:letterSpacing="0.05" android:fontFamily="@font/silkscreen_regular" android:layout_marginBottom="6dp" />
                    <TextView android:id="@+id/tvWeather" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Partly Cloudy\n28°C" android:textSize="11sp" android:textStyle="bold" android:textColor="@color/lilac_blue" android:gravity="center" android:lineSpacingExtra="2dp" android:background="@drawable/bg_value_badge_blue" android:paddingTop="5dp" android:paddingBottom="5dp" />
                </LinearLayout>



                <!-- 4. LAST UPDATED -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_info_card"
                    android:elevation="2dp"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"
                    android:paddingLeft="6dp"
                    android:paddingRight="6dp">
                    <FrameLayout android:layout_width="44dp" android:layout_height="44dp" android:layout_marginBottom="6dp">
                        <View android:layout_width="44dp" android:layout_height="44dp" android:background="@drawable/bg_icon_circle_orange" />
                        <ImageView android:layout_width="26dp" android:layout_height="26dp" android:layout_gravity="center" android:src="@android:drawable/ic_menu_recent_history" android:contentDescription="Last updated icon" />
                    </FrameLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="LAST\nUPDATED" android:textSize="8sp" android:textStyle="bold" android:textColor="@color/text_light" android:gravity="center" android:letterSpacing="0.05" android:fontFamily="@font/silkscreen_regular" android:layout_marginBottom="6dp" />
                    <TextView android:id="@+id/tvLastUpdated" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="10:30" android:textSize="12sp" android:textStyle="bold" android:textColor="@color/primary_orange" android:gravity="center" android:background="@drawable/bg_value_badge_orange" android:paddingTop="5dp" android:paddingBottom="5dp" />
                </LinearLayout>

            </LinearLayout>

            <!-- Hidden legacy views -->
            <LinearLayout android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone">
                <ImageView android:id="@+id/uvGaugeImage" android:layout_width="0dp" android:layout_height="0dp" android:contentDescription="Legacy" />
                <TextView android:id="@+id/tvShade" android:layout_width="0dp" android:layout_height="0dp" android:text="" />
                <androidx.appcompat.widget.SwitchCompat android:id="@+id/switchReminder" android:layout_width="0dp" android:layout_height="0dp" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- BOTTOM NAV -->
    <LinearLayout
        android:id="@+id/bottomNavBar"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_alignParentBottom="true"
        android:background="@color/background_cream"
        android:elevation="8dp"
        android:orientation="horizontal"
        android:paddingLeft="12dp"
        android:paddingRight="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <!-- UV Today (SELECTED) -->
        <LinearLayout
            android:id="@+id/tabUvToday"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_nav_selected_pink"
            android:paddingLeft="12dp"
            android:paddingRight="12dp"
            android:clickable="true"
            android:focusable="true">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="☀️" android:textSize="22sp" android:layout_marginBottom="2dp" />
            <TextView android:id="@+id/tvNavUvToday" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="UV Today" android:textSize="11sp" android:textStyle="bold" android:textColor="@color/warm_pink" android:fontFamily="@font/silkscreen_regular" />
        </LinearLayout>

        <!-- Settings (UNSELECTED) -->
        <LinearLayout
            android:id="@+id/btnSettings"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_nav_unselected"
            android:paddingLeft="12dp"
            android:paddingRight="12dp"
            android:clickable="true"
            android:focusable="true">
            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_settings_gear" android:contentDescription="Settings" android:layout_marginBottom="2dp" />
            <TextView android:id="@+id/tvNavProfile" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Settings" android:textSize="11sp" android:textColor="@color/text_medium" android:fontFamily="@font/silkscreen_regular" />
        </LinearLayout>

    </LinearLayout>

</RelativeLayout>
