<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF8EE"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <!-- Why should I care about UV? -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="10dp">

            <TextView
                android:id="@+id/backButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="← Back"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#C75C67"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:background="@drawable/help_back_button_bg" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sun Protection Guide"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#E06476"
                android:layout_marginTop="14dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Learn why UV protection and sunscreen matter."
                android:textSize="12sp"
                android:textColor="#7A5B57"
                android:layout_marginTop="3dp" />

        </LinearLayout>

        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_settings_card"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Why should I care about UV?"
                    android:textColor="#202020"
                    android:textSize="21sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="UV rays are invisible, but they can still affect your skin. A higher UV Index means stronger sun exposure and a greater need for protection."
                    android:textColor="#444444"
                    android:textSize="15sp" />

            </LinearLayout>








            <!-- Why every 2 hours? -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_settings_card"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Why every 2 hours?"
                    android:textColor="#202020"
                    android:textSize="21sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Sunscreen protection can decrease over time, especially outdoors. Solaria uses the common public health recommendation to reapply sunscreen every 2 hours."
                    android:textColor="#444444"
                    android:textSize="15sp" />

            </LinearLayout>

            <!-- Where does this information come from? -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_settings_card"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Where does this information come from?"
                    android:textColor="#202020"
                    android:textSize="21sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Solaria’s guidance is based on trusted sources such as WHO, EPA, FDA, and the American Academy of Dermatology."
                    android:textColor="#444444"
                    android:textSize="15sp" />

            </LinearLayout>

            <!-- Is this medical advice? -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_settings_card"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Is this medical advice?"
                    android:textColor="#202020"
                    android:textSize="21sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="No. Solaria gives general UV-based sun protection guidance. It does not collect personal data or provide skin-type-based medical recommendations."
                    android:textColor="#444444"
                    android:textSize="15sp" />

            </LinearLayout>

            <!-- Sun Protection Reminder -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_settings_card"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sun Protection Reminder"
                    android:textColor="#202020"
                    android:textSize="21sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Skipping sunscreen can lead to sunburn, dark spots, early skin aging, and long-term UV damage. Solaria reminds you to protect your skin when the UV Index is 3 or higher."
                    android:textColor="#444444"
                    android:textSize="15sp" />

            </LinearLayout>

    </LinearLayout>

</ScrollView>