<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF8EE"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="676dp"
            android:background="@drawable/bg_settings_outer"
            android:orientation="vertical"
            android:padding="22dp">

            <!-- Top Area -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="70dp">

                <TextView
                    android:id="@+id/btnBack"
                    android:layout_width="78dp"
                    android:layout_height="48dp"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:background="@drawable/bg_settings_back_button"
                    android:gravity="center"
                    android:text="Back"
                    android:textColor="#A65B5B"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtSettingsTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:text="Settings"
                    android:textColor="#D86478"
                    android:textSize="30sp"
                    android:textStyle="bold" />

            </RelativeLayout>

            <!-- Notifications Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="145dp"
                android:layout_marginTop="22dp"
                android:background="@drawable/bg_settings_card"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="18dp">

                <ImageView
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:background="@drawable/bg_settings_icon"
                    android:contentDescription="Notifications icon"
                    android:padding="6dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_settings_notifications_cat" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="22dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Notifications"
                        android:textColor="#202020"
                        android:textSize="25sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Enable notifications for reapplication reminders."
                        android:textColor="#444444"
                        android:textSize="16sp" />

                </LinearLayout>

                <Switch
                    android:id="@+id/switchNotifications"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

            </LinearLayout>

            <!-- Location Permission Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="145dp"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_settings_card"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="18dp">

                <ImageView
                    android:layout_width="70dp"
                    android:layout_height="73dp"
                    android:background="@drawable/bg_settings_icon"
                    android:contentDescription="Location icon"
                    android:padding="6dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_settings_location_cat" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="22dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Location Permission"
                        android:textColor="#202020"
                        android:textSize="25sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txtLocationStatus"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Shows whether location permission is granted or denied."
                        android:textColor="#444444"
                        android:textSize="16sp" />

                </LinearLayout>

            </LinearLayout>

            <!-- Offline / Cached Data Card -->

            <!-- Help Card -->
            <LinearLayout
                android:id="@+id/helpCard"
                android:clickable="true"
                android:focusable="true"
                android:layout_width="match_parent"
                android:layout_height="145dp"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_settings_card"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="18dp">

                <ImageView
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:background="@drawable/bg_settings_icon"
                    android:contentDescription="Help icon"
                    android:padding="6dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_settings_help_cat" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="22dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Your Sun Protection Guide"
                        android:textColor="#202020"
                        android:textSize="25sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Learn why UV protection and sunscreen matter."
                        android:textColor="#444444"
                        android:textSize="16sp" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</ScrollView>