<?xml version="1.0" encoding="utf-8"?>
<!--
    bg_uv_slider_track.xml
    UV Index slider barı: yeşil → sarı → turuncu → kırmızı gradient, yuvarlak uçlar.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <gradient
        android:angle="0"
        android:startColor="#4ADE80"
        android:centerColor="#FBBF24"
        android:endColor="#EF4444"
        android:type="linear" />

    <corners android:radius="6dp" />

</shape>
